# Copy this file to .env and fill in the values. NEVER commit your real .env.
# On Railway (or any host), set these as service/environment variables instead.

# Shared password that visitors must enter to use the app.
# Leave unset ONLY for local testing — an unset password means the app is OPEN.
APP_PASSWORD=change-me

# Signs the login/session cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# A fixed value keeps logins valid across restarts; if unset, a random one is
# used each boot (everyone has to log in again after a restart).
SECRET_KEY=

# Optional: set to 1 to force secure (HTTPS-only) cookies. On Railway this is
# auto-enabled, so you normally don't need this.
# SECURE_COOKIES=1

# NOTE: there is no ANTHROPIC_API_KEY here. Each user enters their own Claude
# key in the browser; it is held in memory for their session only.
